# OpenClaw 配置模板
# 复制此文件为 openclaw.json 并修改相关配置

{
  "models": {
    "mode": "merge",
    "providers": {
      "cass-claude": {
        "baseUrl": "http://your-api-url",
        "apiKey": "your-api-key",
        "api": "anthropic-messages"
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/Users/YOUR_USERNAME/.openclaw/agents/main/workspace"
    },
    "list": [
      {
        "id": "dev-assistant",
        "workspace": "/Users/YOUR_USERNAME/.openclaw/agents/dev-assistant/workspace"
      }
    ]
  }
}
